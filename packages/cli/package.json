{
  "name": "@evoframe/cli",
  "version": "0.1.0",
  "bin": {
    "evo": "dist/index.js"
  },
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts && node -e \"const fs=require('fs');const f='dist/index.js';fs.writeFileSync(f,'#!/usr/bin/env node\\n'+fs.readFileSync(f,'utf8'))\"",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "dependencies": {
    "@evoframe/core": "*",
    "@evoframe/0g-adapter": "*",
    "@evoframe/skill-registry": "*",
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "ora": "^8.0.0",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "tsup": "*",
    "typescript": "*",
    "@types/node": "*",
    "@types/prompts": "^2.4.9"
  }
}
