# EvoYield Agent — Environment Variables
# Copy to .env and fill in your values

# ── 0G / EvoFrame (YOUR side) ───────────────────────────────────
COMPUTE_ENDPOINT=https://compute-network-6.integratenetwork.work
ZG_API_KEY=your_0g_api_key_here
COMPUTE_MODE=live
EVOLUTION_MODEL=qwen/qwen-2.5-7b-instruct

# ── 0G Chain + Storage (live on-chain registration & real storage)
# Get testnet A0GI: https://faucet.0g.ai
# ZG_PRIVATE_KEY enables: real 0G Storage uploads + on-chain SkillRegistry + DA broadcast
ZG_PRIVATE_KEY=0x<your_private_key>
ZG_CHAIN_RPC=https://evmrpc-testnet.0g.ai
ZG_STORAGE_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_DA_RPC=https://da-node-testnet.0g.ai

# ── Deployed Contract Addresses (after running contracts/deploy.sh) ──────────
# Deploy: cd contracts && bash deploy.sh
SKILL_REGISTRY_ADDRESS=0x
SKILL_TOKEN_ADDRESS=0x

# ── EvoYield HTTP Server ────────────────────────────────────────
PORT=3001

# ── KeeperHub ───────────────────────────────────────────────────
# Get API key: https://app.keeperhub.com/settings/api-keys
KEEPERHUB_API_KEY=kh_your_keeperhub_api_key_here

# Optional overrides (defaults shown):
# KEEPERHUB_API_URL=https://app.keeperhub.com/api
# KH_MODE=live                                      # set to "mock" for offline dev
# KH_PROJECT_ID=
# KH_TAG_ID=
# KH_WEBHOOK_URL=                                   # optional: direct webhook URL from KeeperHub UI
# KH_WEBHOOK_KEY=                                   # optional: webhook-specific key, not the org kh_ key
# KH_WAIT_FOR_WORKFLOW=true
# KH_WORKFLOW_WAIT_MS=120000
# KH_WALLET_INTEGRATION_ID=
# KH_WALLET_ADDRESS=0xYourKeeperHubWallet

# Optional REST path overrides — only set if your KeeperHub deployment exposes
# different paths than the documented MCP-tool defaults:
# KH_PATH_AI_GENERATE=/ai/generate-workflow
# KH_PATH_CREATE_WORKFLOW=/workflows
# KH_PATH_CHECK_EXEC=/executions/check-and-execute
# KH_PATH_CONTRACT_CALL=/executions/contract-call

# Manual fallback workflow (only used if auto-synth has not registered one yet)
KH_REBALANCE_WORKFLOW_ID=

# ── Sepolia USDC mock-vault demo ─────────────────────────────────
# Deploy contracts/EvoYieldSepoliaMocks.sol from Remix on Ethereum Sepolia.
EVOYIELD_TEST_POOL_USDC=60.1
EVOYIELD_USDC_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
EVOYIELD_REBALANCER_ADDRESS=0xYourSepoliaRebalancer
EVOYIELD_AAVE_VAULT=0xYourAaveMockVault
EVOYIELD_MORPHO_VAULT=0xYourMorphoMockVault
EVOYIELD_YEARN_VAULT=0xYourYearnMockVault
EVOYIELD_SKY_VAULT=0xYourSkyMockVault

# Public URL of THIS agent. The synthesised KeeperHub workflow will call
# /evaluate and /regenerate at this base URL on every scheduled run.
# In dev: `npx ngrok http 3001` then paste the https URL here.
EVOYIELD_PUBLIC_URL=

# ── x402 (pay-per-call gating on /evaluate) ─────────────────────
# Leave X402_RECEIVER unset to keep /evaluate free during development.
# X402_RECEIVER=0xYourTreasuryAddress
# X402_NETWORK=base
# X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913        # USDC on Base
# X402_DECIMALS=6
# X402_PRICE_USDC=0.01
# X402_FACILITATOR_URL=https://facilitator.x402.org
# X402_VERIFY=true

# ── Discord Notifications ──────────────────────────────────────
# In your Discord server: pick a channel → ⚙ Edit Channel → Integrations
# → Webhooks → New Webhook → Copy URL → paste below.
# Leave blank to disable notifications.
DISCORD_WEBHOOK_URL=your_discord_webhook_url

# Optional cosmetic overrides
# DISCORD_USERNAME=EvoYield
# DISCORD_AVATAR_URL=https://your.cdn/evoyield-avatar.png
