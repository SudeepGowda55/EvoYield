# EvoYield Agent — Environment Variables
# Copy to .env and fill in your values

# ── 0G / EvoFrame (YOUR side) ───────────────────────────────────
COMPUTE_ENDPOINT=https://compute-network-6.integratenetwork.work
ZG_API_KEY=your-0g-api-key-here
COMPUTE_MODE=live
EVOLUTION_MODEL=qwen/qwen-2.5-7b-instruct

# ── EvoYield HTTP Server ────────────────────────────────────────
PORT=3001

# ── KeeperHub (FRIEND's side) ───────────────────────────────────
# Get API key: https://app.keeperhub.com/settings/api-keys
KEEPERHUB_API_KEY=kh_your_key_here

# Create a webhook-triggered rebalance workflow in KeeperHub UI, paste its ID here
# Workflow should: read balances → compare allocation → withdraw/deposit → notify
KH_REBALANCE_WORKFLOW_ID=wf_your_workflow_id_here

# ── Telegram Notifications ──────────────────────────────────────
# 1. Open Telegram → message @BotFather → /newbot → copy the token
# 2. Start your bot, then visit:
#    https://api.telegram.org/bot{TOKEN}/getUpdates
#    Find "chat": { "id": ... } — that is your chat ID
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id
